<?xml version="1.0"?>
<ruleset name="WPDev">
    <description>PSR-12 coding standard for wpdev/phpspreadsheet-odata</description>

    <arg name="colors"/>
    <arg value="sp"/>

    <config name="installed_paths" value="vendor/phpcompatibility/php-compatibility"/>
    <config name="testVersion" value="7.4-"/>

    <file>src</file>
    <file>tests</file>

    <rule ref="PSR12"/>

    <rule ref="PHPCompatibility">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>

    <rule ref="Generic.PHP.RequireStrictTypes"/>

    <!-- Allow snake_case test method names when using #[Test] attributes -->
    <rule ref="PSR1.Methods.CamelCapsMethodName.NotCamelCaps">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>

    <!-- Suppress line-length warnings for complex XML/XPath strings -->
    <rule ref="Generic.Files.LineLength.TooLong">
        <severity>0</severity>
    </rule>
</ruleset>
