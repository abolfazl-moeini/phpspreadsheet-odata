{
    "name": "wpdev/phpspreadsheet-odata",
    "description": "Framework-agnostic OData v4 read-only feed for PhpSpreadsheet workbooks",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^7.4|^8.0",
        "phpoffice/phpspreadsheet": "^1.29|^2.0|^3.0|^4.0|^5.0",
        "psr/http-message": "^1.0|^2.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6|^10.5|^11.0",
        "phpstan/phpstan": "^1.10|^2.2"
    },
    "autoload": {
        "psr-4": {
            "WPDev\\PhpSpreadsheetOData\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPDev\\PhpSpreadsheetOData\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}