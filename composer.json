{
    "name": "wpdev/phpspreadsheet-odata",
    "description": "Framework-agnostic OData v4 read-only feed for PhpSpreadsheet workbooks",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "odata",
        "odata-v4",
        "phpspreadsheet",
        "excel",
        "spreadsheet",
        "psr-7",
        "rest-api"
    ],
    "authors": [
        {
            "name": "WPDev",
            "homepage": "https://github.com/wpdev"
        }
    ],
    "require": {
        "php": ">=7.4",
        "phpoffice/phpspreadsheet": "^1.29|^2.0|^3.0|^4.0|^5.0",
        "psr/http-message": "^1.0|^2.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6|^10.5|^11.0",
        "phpstan/phpstan": "^1.10|^2.2"
    },
    "autoload": {
        "psr-4": {
            "WPDev\\PhpSpreadsheetOData\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPDev\\PhpSpreadsheetOData\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}